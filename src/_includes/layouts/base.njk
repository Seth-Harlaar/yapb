<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Blog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400&family=Honk&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  <script>
    // Seed localStorage on first visit so the blog starts in carnival.
    // Pre-creates the link elements sp-theme.js will reuse, preventing flash.
    (function () {
      var saved = localStorage.getItem('sp-theme');
      if (!saved) { saved = 'default'; localStorage.setItem('sp-theme', saved); }
      var base = 'https://cdn.jsdelivr.net/gh/Seth-Harlaar/sp-components@latest/themes/';
      document.documentElement.setAttribute('data-theme', saved);
      function mkLink(id, href) {
        var el = document.createElement('link');
        el.rel = 'stylesheet'; el.id = id; el.href = href;
        document.head.appendChild(el);
      }
      mkLink('sp-theme-tokens', base + 'default.css');
      mkLink('sp-theme-active', base + saved + '.css');
    })();
  </script>
</head>
<body>
  <sp-theme></sp-theme>

  <header>
    {% include "partials/nav.njk" %}
  </header>

  <main>
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <script type="module">
    import 'https://cdn.jsdelivr.net/gh/Seth-Harlaar/sp-components@latest/components/sp-theme.js'
    import 'https://cdn.jsdelivr.net/gh/Seth-Harlaar/sp-components@latest/components/sp-nav.js'
  </script>
</body>
</html>
