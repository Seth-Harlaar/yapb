---
layout: layouts/base.njk
---
<article class="post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <time datetime="{{ date | dateISO }}">{{ date | dateFormat }}</time>
    {% if tags %}
    <ul class="tags">
      {% for tag in tags %}
        {% if tag != "posts" %}
        <li><sp-tag color="primary">{{ tag }}</sp-tag></li>
        {% endif %}
      {% endfor %}
    </ul>
    {% endif %}
  </header>

  <div class="post-body">
    {{ content | safe }}
  </div>
</article>
