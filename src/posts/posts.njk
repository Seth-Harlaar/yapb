---
layout: layouts/base.njk
title: Posts
permalink: /posts/
---
<script type="module">
  import 'https://cdn.jsdelivr.net/gh/Seth-Harlaar/sp-components@latest/components/sp-button.js'
</script>
<h1>All Posts</h1>

{% set allTags = [] %}
{% for post in collections.posts %}
  {% for tag in post.data.tags %}
    {% if tag != "posts" and tag not in allTags %}
      {% set allTags = allTags.concat([tag]) %}
    {% endif %}
  {% endfor %}
{% endfor %}

{% if allTags.length %}
<div class="tag-filter">
  <sp-button data-tag="all" variant="primary">All</sp-button>
  {% for tag in allTags %}
  <sp-button data-tag="{{ tag }}">{{ tag }}</sp-button>
  {% endfor %}
</div>
{% endif %}

{% if collections.posts.length %}
<ol class="post-list">
  {% for post in collections.posts %}
  <li data-tags="{{ post.data.tags | join(' ') }}">
    <a href="{{ post.url | url }}">{{ post.data.title }}</a>
    <time datetime="{{ post.date | dateISO }}">{{ post.date | dateFormat }}</time>
  </li>
  {% endfor %}
</ol>
{% else %}
<p>No posts yet.</p>
{% endif %}

<script>
  const buttons = document.querySelectorAll('sp-button[data-tag]');
  const items   = document.querySelectorAll('.post-list li');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.removeAttribute('variant'));
      btn.setAttribute('variant', 'primary');

      const selected = btn.dataset.tag;
      items.forEach(item => {
        const tags = item.dataset.tags ? item.dataset.tags.split(' ') : [];
        item.style.display = (selected === 'all' || tags.includes(selected)) ? '' : 'none';
      });
    });
  });
</script>
